DEFAULT_CONFIG = """\
[paths]
# JSON с цветами, сгенерированный Noctalia
colors = ~/.config/noctalia/colors.json
# Итоговый ZIP с темой для Telegram
output = ~/.cache/telegram-theme-noctalia/noctalia.tdesktop-theme

[pack]
# Генерировать тайловый PNG-паттерн в качестве фона чатов.
# Требует Python-пакет Pillow (pip install pillow).
background = true
"""


def load_config() -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    if CONFIG.exists():
        cfg.read(CONFIG)
    return cfg


def get_paths(cfg: configparser.ConfigParser) -> SimpleNamespace:
    def p(key: str, default: Path) -> Path:
        return Path(cfg.get("paths", key, fallback=str(default))).expanduser()

    colors = p("colors", NOCTALIA_COLORS)
    output = p("output", HOME / ".cache/telegram-theme-noctalia/noctalia.tdesktop-theme")
    return SimpleNamespace(
        colors=colors,
        output=output,
        cache=output.parent,
    )


# ── Обработка цветов ──────────────────────────────────────────────────────

def _hex_to_rgb(h: str) -> tuple:
    h = h.lstrip("#")
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def _blend(hex1: str, hex2: str, ratio: float) -> str:
    """Смешать два цвета. ratio=0 → hex1, ratio=1 → hex2"""
    r1, g1, b1 = _hex_to_rgb(hex1)
    r2, g2, b2 = _hex_to_rgb(hex2)
    r = int(r1 + (r2 - r1) * ratio)
    g = int(g1 + (g2 - g1) * ratio)
    b = int(b1 + (b2 - b1) * ratio)
    return f"#{r:02x}{g:02x}{b:02x}"


def load_colors(colors_path: Path) -> dict:
    """Загрузить colors.json Noctalia и вывести полный словарь цветов для Telegram.

    Noctalia экспортирует только 14 базовых цветов (mPrimary, mSurface, …).
    Недостающие Material You цвета (контейнеры, поверхности) вычисляются
    через линейную интерполяцию между surface и соответствующим акцентом.
    """
    raw = json.loads(colors_path.read_text())

    p   = raw["mPrimary"]
    op  = raw["mOnPrimary"]
    s   = raw["mSecondary"]
    os_ = raw["mOnSecondary"]
    t   = raw["mTertiary"]
    ot  = raw["mOnTertiary"]
    e   = raw["mError"]
    oe  = raw["mOnError"]
    su  = raw["mSurface"]
    osu = raw["mOnSurface"]
    sv  = raw["mSurfaceVariant"]
    osv = raw["mOnSurfaceVariant"]
    ol  = raw["mOutline"]
    hv  = raw.get("mHover", t)

    return {
        "primary":                 p,
        "onPrimary":               op,
        "primaryContainer":        _blend(su, p, 0.28),
        "onPrimaryContainer":      p,

        "secondary":               s,
        "onSecondary":             os_,
        "secondaryContainer":      _blend(su, s, 0.28),
        "onSecondaryContainer":    s,

        "tertiary":                t,
        "onTertiary":              ot,
        "tertiaryContainer":       _blend(su, t, 0.28),
        "onTertiaryContainer":     t,

        "error":                   e,
        "onError":                 oe,
        "errorContainer":          _blend(su, e, 0.28),
        "onErrorContainer":        e,

        "surface":                 su,
        "onSurface":               osu,
        "surfaceVariant":          sv,
        "onSurfaceVariant":        osv,

        "surfaceContainerLowest":  su,
        "surfaceContainerLow":     _blend(su, sv, 0.33),
        "surfaceContainer":        _blend(su, sv, 0.50),
        "surfaceContainerHigh":    _blend(su, sv, 0.67),
        "surfaceContainerHighest": sv,

        "outline":                 ol,
        "outlineVariant":          ol,

        # Для иконок контактов используем доступные акцентные цвета
        "term1": p,
        "term2": s,
        "term3": t,
        "term4": e,
        "term5": hv,
    }


def _expand_template(template: str, colors: dict) -> str:
    """Раскрыть {{ name.hexalpha }} и {{ name.hex }} в hex-значения."""
    def replace(m: re.Match) -> str:
        name   = m.group(1)
        suffix = m.group(2)
        hex6 = colors.get(name, "#000000").lstrip("#")
        if suffix == "hexalpha":
            return f"#{hex6}ff"
        return f"#{hex6}"
    return re.sub(r"\{\{\s*(\w+)\.(hexalpha|hex)\s*\}\}", replace, template)


