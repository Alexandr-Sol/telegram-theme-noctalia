# ── Команды ────────────────────────────────────────────────────────────────

def cmd_pack():
    cfg = load_config()
    paths = get_paths(cfg)
    use_bg = cfg.getboolean("pack", "background", fallback=True)

    if not paths.colors.exists():
        die(f"Файл цветов Noctalia не найден: {paths.colors}\n  Смените тему в Noctalia хотя бы один раз.")

    colors = load_colors(paths.colors)
    theme_content = _expand_template(TEMPLATE_CONTENT, colors)

    pattern_png = None
    if use_bg:
        try:
            from PIL import Image, ImageDraw
        except ImportError:
            die(
                "Python-пакет Pillow не установлен (pip install pillow).\n"
                f"  Или отключите фон в конфиге: {CONFIG}\n"
                "  background = false"
            )

        def hex_to_rgb(h: str) -> tuple:
            h = h.lstrip("#")
            return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)

        def make_pattern(surface: tuple, dot_color: tuple) -> bytes:
            img = Image.new("RGB", (TILE, TILE), surface)
            overlay = Image.new("RGBA", (TILE, TILE), (0, 0, 0, 0))
            draw = ImageDraw.Draw(overlay)
            half = TILE // 2
            for x, y in [(0, 0), (half, half), (TILE, 0), (0, TILE), (TILE, TILE)]:
                draw.ellipse([x - DOT_R, y - DOT_R, x + DOT_R, y + DOT_R], fill=(*dot_color, ALPHA))
            img.paste(overlay, mask=overlay)
            buf = io.BytesIO()
            img.save(buf, "PNG")
            return buf.getvalue()

        pattern_png = make_pattern(
            hex_to_rgb(colors.get("surface", "#000000")),
            hex_to_rgb(colors.get("primary", "#ffffff")),
        )

    paths.cache.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(paths.output, "w", zipfile.ZIP_DEFLATED) as zf:
        zf.writestr("colors.tdesktop-theme", theme_content)
        if pattern_png is not None:
            zf.writestr("tiled.png", pattern_png)
    print(f"packed → {paths.output}")


def cmd_install():
    if not CONFIG.exists():
        write_file(CONFIG, DEFAULT_CONFIG, "конфиг")
    else:
        info(f"Конфиг уже существует: {CONFIG}")

    cfg = load_config()
    paths = get_paths(cfg)

    if cfg.getboolean("pack", "background", fallback=True):
        try:
            import PIL  # noqa: F401
        except ImportError:
            warn("Pillow не установлен — фон чатов не будет сгенерирован.")
            warn("  Установите: pip install pillow")
            warn(f"  Или отключите: {CONFIG}  →  background = false")

    paths.cache.mkdir(parents=True, exist_ok=True)

    if NOCTALIA_COLORS.exists():
        info("Запускаю первую упаковку темы...")
        cmd_pack()

    hook_cmd = f"{Path(__file__).resolve()} pack"
    print("\n" + "="*70)
    ok("Установка файлов завершена.")
    print("\nДля автоматического обновления темы добавьте эту команду в Noctalia:")
    print("Настройки -> Хуки -> Генерация цвета (Settings -> Hooks -> Color Generation)")
    print(f"\n  {hook_cmd}")
    print("\n" + "="*70 + "\n")


def cmd_uninstall():
    cfg = load_config()
    paths = get_paths(cfg)

    if CONFIG.exists():
        CONFIG.unlink()
        ok(f"Удалён: {CONFIG}")

    if paths.cache.exists():
        shutil.rmtree(paths.cache)
        ok(f"Удалена директория: {paths.cache}")

    ok("Удаление завершено")


def cmd_paths():
    cfg = load_config()
    paths = get_paths(cfg)

    def status(path: Path) -> str:
        return "✓" if path.exists() else "✗"

    rows = [
        ("Конфиг",           CONFIG),
        ("Цвета Noctalia",   paths.colors),
        ("ZIP тема",         paths.output),
    ]
    width = max(len(label) for label, _ in rows)
    for label, path in rows:
        print(f"  {status(path)}  {label:{width}}  {path}")


# ── Точка входа ────────────────────────────────────────────────────────────

COMMANDS = {
    "install":         cmd_install,
    "uninstall":       cmd_uninstall,
    "pack":            cmd_pack,
    "paths":           cmd_paths,
}

if len(sys.argv) != 2 or sys.argv[1] not in COMMANDS:
    print(__doc__)
    sys.exit(1)

COMMANDS[sys.argv[1]]()
