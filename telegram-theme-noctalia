#!/usr/bin/env python3
"""Управление автоматической темой Telegram на основе Noctalia.

Использование:
  telegram-theme-noctalia install    — установить конфиг и показать команду для хука Noctalia
  telegram-theme-noctalia uninstall  — удалить все файлы
  telegram-theme-noctalia pack       — упаковать тему в ZIP (выполняется хуком)
  telegram-theme-noctalia paths      — показать все пути и их статус
"""

import configparser
import io
import json
import re
import shutil
import subprocess
import sys
import zipfile
from pathlib import Path
from types import SimpleNamespace

HOME      = Path.home()
CONFIG    = HOME / ".config/telegram-theme-noctalia/config"

TILE  = 60
DOT_R = 3
ALPHA = 40

NOCTALIA_COLORS = HOME / ".config/noctalia/colors.json"


def info(msg): print(f"→ {msg}")
def ok(msg):   print(f"✓ {msg}")
def warn(msg): print(f"! {msg}")
def die(msg):  sys.exit(f"✗ {msg}")


def write_file(path: Path, content: str, label: str):
    if path.exists():
        warn(f"{label} уже существует, перезаписываю: {path}")
    else:
        info(f"Создаю {label}: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


